# ══════════════════════════════════════════════════════════════════════════════
#  AI Response Guardian — Root .env (used by docker-compose)
#  Copy this to .env and fill in the values before running docker-compose up
# ══════════════════════════════════════════════════════════════════════════════

# ─── SHARED SECRET (must match in backend AND proxy) ──────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROXY_SECRET_KEY=change_me_shared_secret_32_chars_minimum

# ─── Backend JWT secret ────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_64_chars_jwt_secret_minimum_length_required_here_x

# ─── Proxy behaviour ───────────────────────────────────────────────────────────
# "warn" → warn on high, block on critical (recommended default)
# "block" → block both high AND critical
POLICY_THRESHOLD=warn

# Set to 1 to test scanning without blocking any traffic or reporting incidents
DRY_RUN=0

# Proxy log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
