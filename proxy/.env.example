# ── Guardian Proxy Engine — Environment Variables ──────────────────────────────

# ─── REQUIRED ──────────────────────────────────────────────────────────────────

# Must exactly match PROXY_SECRET_KEY in the backend .env
PROXY_SECRET_KEY=change_me_to_a_32_char_random_string

# ─── Backend connection ─────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:4000

# ─── Proxy listener ─────────────────────────────────────────────────────────────
PROXY_HOST=0.0.0.0
PROXY_PORT=8080

# ─── Behaviour ──────────────────────────────────────────────────────────────────

# "warn"  → warn on high, block on critical  (default)
# "block" → block on high AND critical
POLICY_THRESHOLD=warn

# Set to 1 to scan without blocking or reporting (testing/evaluation mode)
DRY_RUN=0

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Set to 1 to log full request/response bodies (CAUTION: may log sensitive data)
LOG_BODIES=0

# Max body size to scan in bytes (default 512KB — larger bodies are skipped)
MAX_BODY_BYTES=512000

# Optional: tag incidents with a device/hostname identifier
# DEVICE_ID=my-laptop-hostname

# ─── TLS/SSL ────────────────────────────────────────────────────────────────────
# Optional: use a custom CA instead of mitmproxy's auto-generated one
# SSL_CA_CERT=/path/to/ca-cert.pem
# SSL_CA_KEY=/path/to/ca-key.pem

# ─── Bypass list ────────────────────────────────────────────────────────────────
# Comma-separated hosts to skip (never scanned)
# BYPASS_HOSTS=internal.mycompany.com,staging.mycompany.com
