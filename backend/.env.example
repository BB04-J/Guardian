# ─── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_64_char_random_string

# ─── Proxy Engine Shared Secret ───────────────────────
# Must match PROXY_SECRET_KEY in PRD 3 (.env of proxy engine)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROXY_SECRET_KEY=change_me_to_a_32_char_random_string

# ─── Database ─────────────────────────────────────────
DB_PATH=./data/guardian.db
